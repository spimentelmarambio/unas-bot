# Postgres (Neon) — MISMA base de datos que usa el proyecto Lukas. El
# "?schema=unas_bot" al final es obligatorio: sin eso, Prisma administra el
# schema "public" completo (el de Lukas) y "migrate dev"/"migrate deploy"
# pueden intentar borrar sus tablas al detectar "drift". Con schema=unas_bot,
# este proyecto crea y usa su propio schema de Postgres, totalmente aislado.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&schema=unas_bot"
# Conexión directa (no pooled) de Neon, requerida por `prisma migrate deploy`.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require&schema=unas_bot"

# Anthropic (Claude API)
ANTHROPIC_API_KEY=""
# Haiku - cheapest tier, más que suficiente para clasificar mensajes cortos.
CLAUDE_MODEL="claude-haiku-4-5-20251001"

# WhatsApp Cloud API (Meta for Developers -> tu app -> WhatsApp -> API Setup)
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Cualquier string que elijas - lo mismo que configures en el dashboard de
# Meta al conectar el webhook (Configuration -> Webhook -> Verify token).
WHATSAPP_VERIFY_TOKEN=""
# App secret de tu app de Meta (Settings -> Basic -> App secret) - se usa
# para verificar la firma X-Hub-Signature-256 de cada webhook entrante.
WHATSAPP_APP_SECRET=""
# Número(s) de WhatsApp autorizados a hablarle al bot, en formato E.164 sin
# "+" (ej: 56912345678). Separados por coma si hay más de uno.
WHATSAPP_ALLOWED_FROM=""

# Contraseña compartida para /dashboard (HTTP Basic Auth - el navegador pide
# usuario y contraseña, pero el usuario no se valida, solo la contraseña).
DASHBOARD_PASSWORD=""
