generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

// Two layers of isolation from Lukas's "public" schema, both needed:
// 1. The connection string carries `?schema=unas_bot`, which the migrate
//    CLI (native engine) uses to resolve its own `_prisma_migrations`
//    bookkeeping table into "unas_bot" instead of colliding with Lukas's
//    migration history in "public".
// 2. `schemas = ["unas_bot"]` + `@@schema("unas_bot")` on every model below,
//    which makes Prisma Client always emit schema-qualified SQL
//    (`"unas_bot"."NailTransaction"`) regardless of the connection's
//    default search_path. This part is required for the *running app*:
//    the Neon driver adapter (@prisma/adapter-neon, used in lib/prisma.ts)
//    does NOT honor the `?schema=` query param at runtime - without
//    `@@schema()`, the app queries "public" and fails with "table does not
//    exist" even though migrations correctly created the table in
//    "unas_bot".
datasource db {
  provider = "postgresql"
  schemas  = ["unas_bot"]
}

enum NailTransactionType {
  INCOME
  EXPENSE

  @@schema("unas_bot")
}

// The business only offers these 3 services - Claude classifies every
// log_income message into exactly one of these (see lib/claude.ts), so
// the dashboard can filter income by service type.
enum NailServiceType {
  ESMALTADO_PERMANENTE
  GEL_X
  KAPPING

  @@schema("unas_bot")
}

model NailTransaction {
  id           String              @id @default(cuid())
  type         NailTransactionType
  amount       Decimal             @db.Decimal(14, 2)
  description  String
  // Only set for INCOME (always null for EXPENSE) - the classified service.
  serviceType  NailServiceType?
  // Only meaningful for INCOME (who got the service) - always null for EXPENSE.
  clientName   String?
  note         String?
  date         DateTime            @default(now())
  whatsappFrom String
  // wamid of the WhatsApp message that produced this row - lets the webhook
  // detect a redelivered message (Meta retries, or our reply failing to
  // send after the transaction was already saved) and skip logging it twice.
  whatsappMessageId String?
  createdAt    DateTime            @default(now())

  @@index([date])
  @@index([type])
  @@index([serviceType])
  @@index([whatsappMessageId])
  @@schema("unas_bot")
}
