generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

// The connection string carries `?schema=unas_bot` (see .env / .env.example),
// which makes Postgres's search_path resolve to that schema by default for
// this connection - so this project (including Prisma's own internal
// _prisma_migrations bookkeeping table) only ever creates/reads/writes
// inside "unas_bot", never "public" (Lukas's schema). Do NOT switch this to
// the `schemas = [...]` + `@@schema(...)` multi-schema feature instead: that
// only scopes the *models*, not Prisma's internal migrations table, which
// still resolves through the connection's default search_path ("public")
// and would then collide with Lukas's own migration history.
datasource db {
  provider = "postgresql"
}

model NailIncomeEntry {
  id           String   @id @default(cuid())
  amount       Decimal  @db.Decimal(14, 2)
  service      String
  clientName   String?
  note         String?
  date         DateTime @default(now())
  whatsappFrom String
  createdAt    DateTime @default(now())

  @@index([date])
}
